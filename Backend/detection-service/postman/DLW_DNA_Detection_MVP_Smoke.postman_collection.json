{
  "info": {
    "_postman_id": "d8e2b9af-6d95-4e4a-b7fe-76c0188d3557",
    "name": "DLW DNA Detection MVP Smoke",
    "description": "Smoke tests for detection service and backend forwarding flow.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Backend Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{backend_url}}/health",
          "host": [
            "{{backend_url}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "2. Detection Service Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{detection_url}}/health",
          "host": [
            "{{detection_url}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "3. Detection Ingest -> Backend Forward (Success)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "x-detection-key",
            "value": "{{detection_service_ingest_key}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"camera_id\": \"CAM-01\",\n  \"confidence\": 0.92,\n  \"description\": \"Manual ingest smoke test\",\n  \"detected_at\": \"2026-03-02T00:00:00Z\",\n  \"metadata\": {\n    \"test\": \"manual_ingest\"\n  }\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{detection_url}}/api/detection/ingest",
          "host": [
            "{{detection_url}}"
          ],
          "path": [
            "api",
            "detection",
            "ingest"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Forwarded to backend and created report', function () {",
              "  var body = pm.response.json();",
              "  pm.expect(body.server_status).to.eql(201);",
              "});"
            ]
          }
        }
      ]
    },
